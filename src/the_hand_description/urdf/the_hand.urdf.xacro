<?xml version="1.0"?>
<robot name="the_hand" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ============================================================
       THE HAND — 6DOF Robotic Arm
       Author: Ramy Wahib
       ROS 2 Jazzy + Gazebo Harmonic

       PARAMETERIZATION GUIDE:
       All geometry is driven by the properties below.
       To resize the arm, change values in this section only.
       Link lengths are in metres.
  ============================================================ -->

  <!-- ── LINK DIMENSIONS ── -->
  <xacro:property name="base_radius"       value="0.045"/>
  <xacro:property name="base_height"       value="0.040"/>

  <xacro:property name="link1_radius"      value="0.022"/>  <!-- shoulder -->
  <xacro:property name="link1_length"      value="0.090"/>

  <xacro:property name="link2_radius"      value="0.020"/>  <!-- upper arm -->
  <xacro:property name="link2_length"      value="0.110"/>

  <xacro:property name="link3_radius"      value="0.018"/>  <!-- forearm -->
  <xacro:property name="link3_length"      value="0.095"/>

  <xacro:property name="link4_radius"      value="0.016"/>  <!-- wrist roll -->
  <xacro:property name="link4_length"      value="0.045"/>

  <xacro:property name="link5_radius"      value="0.016"/>  <!-- wrist pitch -->
  <xacro:property name="link5_length"      value="0.040"/>

  <xacro:property name="link6_radius"      value="0.020"/>  <!-- wrist yaw housing -->
  <xacro:property name="link6_length"      value="0.035"/>

  <!-- ── GRIPPER DIMENSIONS ── -->
  <xacro:property name="palm_x"            value="0.040"/>
  <xacro:property name="palm_y"            value="0.036"/>
  <xacro:property name="palm_z"            value="0.018"/>

  <xacro:property name="finger_x"          value="0.008"/>
  <xacro:property name="finger_y"          value="0.008"/>
  <xacro:property name="finger_z"          value="0.040"/>

  <xacro:property name="finger_spread"     value="0.014"/>  <!-- half-gap between fingers -->

  <!-- ── CAMERA ── -->
  <xacro:property name="camera_x"          value="0.020"/>
  <xacro:property name="camera_y"          value="0.020"/>
  <xacro:property name="camera_z"          value="0.012"/>

  <!-- ── JOINT LIMITS (radians) ── -->
  <xacro:property name="joint1_lower"      value="${-pi}"/>
  <xacro:property name="joint1_upper"      value="${pi}"/>

  <xacro:property name="joint2_lower"      value="${-pi/2}"/>
  <xacro:property name="joint2_upper"      value="${pi/2}"/>

  <xacro:property name="joint3_lower"      value="${-pi/2}"/>
  <xacro:property name="joint3_upper"      value="${pi*0.75}"/>

  <xacro:property name="joint4_lower"      value="${-pi}"/>
  <xacro:property name="joint4_upper"      value="${pi}"/>

  <xacro:property name="joint5_lower"      value="${-pi/2}"/>
  <xacro:property name="joint5_upper"      value="${pi/2}"/>

  <xacro:property name="joint6_lower"      value="${-pi}"/>
  <xacro:property name="joint6_upper"      value="${pi}"/>

  <xacro:property name="gripper_lower"     value="0.0"/>
  <xacro:property name="gripper_upper"     value="0.025"/>

  <!-- ── DYNAMICS ── -->
  <xacro:property name="joint_damping"     value="0.5"/>
  <xacro:property name="joint_friction"    value="0.1"/>
  <xacro:property name="joint_effort"      value="10.0"/>
  <xacro:property name="joint_velocity"    value="2.0"/>

  <!-- ── MATERIALS ── -->
  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="mid_grey">
    <color rgba="0.4 0.4 0.4 1.0"/>
  </material>
  <material name="cyan">
    <color rgba="0.024 0.714 0.831 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>

  <!-- ============================================================
       INERTIA MACROS
       Approximate inertia tensors for primitive shapes.
       Mass values are rough estimates — refine after CAD.
  ============================================================ -->

  <xacro:macro name="inertial_cylinder" params="mass radius length">
    <inertial>
      <mass value="${mass}"/>
      <inertia
        ixx="${(1.0/12.0) * mass * (3 * radius*radius + length*length)}"
        iyy="${(1.0/12.0) * mass * (3 * radius*radius + length*length)}"
        izz="${0.5 * mass * radius*radius}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="inertial_box" params="mass x y z">
    <inertial>
      <mass value="${mass}"/>
      <inertia
        ixx="${(1.0/12.0) * mass * (y*y + z*z)}"
        iyy="${(1.0/12.0) * mass * (x*x + z*z)}"
        izz="${(1.0/12.0) * mass * (x*x + y*y)}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <!-- ============================================================
       BASE LINK
  ============================================================ -->

  <link name="world"/>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${base_radius}" length="${base_height}"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${base_radius}" length="${base_height}"/>
      </geometry>
    </collision>
    <xacro:inertial_cylinder mass="0.300" radius="${base_radius}" length="${base_height}"/>
  </link>

  <!-- ============================================================
       JOINT 1 — WAIST ROTATION (Z-axis)
       DOF 1: spins the entire arm left/right
  ============================================================ -->

  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child  link="link_1"/>
    <origin xyz="0 0 ${base_height}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${joint1_lower}" upper="${joint1_upper}"
           effort="${joint_effort}" velocity="${joint_velocity}"/>
    <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
  </joint>

  <link name="link_1">
    <visual>
      <origin xyz="0 0 ${link1_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${link1_radius}" length="${link1_length}"/>
      </geometry>
      <material name="mid_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${link1_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${link1_radius}" length="${link1_length}"/>
      </geometry>
    </collision>
    <xacro:inertial_cylinder mass="0.180" radius="${link1_radius}" length="${link1_length}"/>
  </link>

  <!-- ============================================================
       JOINT 2 — SHOULDER PITCH (Y-axis)
       DOF 2: tilts lower arm up/down
  ============================================================ -->

  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child  link="link_2"/>
    <origin xyz="0 0 ${link1_length}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${joint2_lower}" upper="${joint2_upper}"
           effort="${joint_effort}" velocity="${joint_velocity}"/>
    <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
  </joint>

  <link name="link_2">
    <visual>
      <origin xyz="0 0 ${link2_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${link2_radius}" length="${link2_length}"/>
      </geometry>
      <material name="mid_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${link2_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${link2_radius}" length="${link2_length}"/>
      </geometry>
    </collision>
    <xacro:inertial_cylinder mass="0.160" radius="${link2_radius}" length="${link2_length}"/>
  </link>

  <!-- ============================================================
       JOINT 3 — ELBOW PITCH (Y-axis)
       DOF 3: bends the forearm at the elbow
  ============================================================ -->

  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child  link="link_3"/>
    <origin xyz="0 0 ${link2_length}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${joint3_lower}" upper="${joint3_upper}"
           effort="${joint_effort}" velocity="${joint_velocity}"/>
    <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
  </joint>

  <link name="link_3">
    <visual>
      <origin xyz="0 0 ${link3_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${link3_radius}" length="${link3_length}"/>
      </geometry>
      <material name="mid_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${link3_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${link3_radius}" length="${link3_length}"/>
      </geometry>
    </collision>
    <xacro:inertial_cylinder mass="0.140" radius="${link3_radius}" length="${link3_length}"/>
  </link>

  <!-- ============================================================
       JOINT 4 — WRIST ROLL (X-axis / arm axis)
       DOF 4: spins the forearm along its own axis
  ============================================================ -->

  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child  link="link_4"/>
    <origin xyz="0 0 ${link3_length}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${joint4_lower}" upper="${joint4_upper}"
           effort="${joint_effort}" velocity="${joint_velocity}"/>
    <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
  </joint>

  <link name="link_4">
    <visual>
      <origin xyz="0 0 ${link4_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${link4_radius}" length="${link4_length}"/>
      </geometry>
      <material name="cyan"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${link4_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${link4_radius}" length="${link4_length}"/>
      </geometry>
    </collision>
    <xacro:inertial_cylinder mass="0.080" radius="${link4_radius}" length="${link4_length}"/>
  </link>

  <!-- ============================================================
       JOINT 5 — WRIST PITCH (Y-axis)
       DOF 5: tilts the wrist up/down
  ============================================================ -->

  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child  link="link_5"/>
    <origin xyz="0 0 ${link4_length}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${joint5_lower}" upper="${joint5_upper}"
           effort="${joint_effort}" velocity="${joint_velocity}"/>
    <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
  </joint>

  <link name="link_5">
    <visual>
      <origin xyz="0 0 ${link5_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${link5_radius}" length="${link5_length}"/>
      </geometry>
      <material name="cyan"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${link5_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${link5_radius}" length="${link5_length}"/>
      </geometry>
    </collision>
    <xacro:inertial_cylinder mass="0.070" radius="${link5_radius}" length="${link5_length}"/>
  </link>

  <!-- ============================================================
       JOINT 6 — WRIST YAW (Z-axis)
       DOF 6: rotates the wrist left/right
  ============================================================ -->

  <joint name="joint_6" type="revolute">
    <parent link="link_5"/>
    <child  link="link_6"/>
    <origin xyz="0 0 ${link5_length}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${joint6_lower}" upper="${joint6_upper}"
           effort="${joint_effort}" velocity="${joint_velocity}"/>
    <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
  </joint>

  <link name="link_6">
    <visual>
      <origin xyz="0 0 ${link6_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${link6_radius}" length="${link6_length}"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${link6_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${link6_radius}" length="${link6_length}"/>
      </geometry>
    </collision>
    <xacro:inertial_cylinder mass="0.060" radius="${link6_radius}" length="${link6_length}"/>
  </link>

  <!-- ============================================================
       GRIPPER — 2-FINGER
       Palm + left finger + right finger
       Gripper joints are prismatic (linear open/close)
  ============================================================ -->

  <joint name="joint_gripper_base" type="fixed">
    <parent link="link_6"/>
    <child  link="gripper_base"/>
    <origin xyz="0 0 ${link6_length}" rpy="0 0 0"/>
  </joint>

  <link name="gripper_base">
    <visual>
      <origin xyz="0 0 ${palm_z/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${palm_x} ${palm_y} ${palm_z}"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${palm_z/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${palm_x} ${palm_y} ${palm_z}"/>
      </geometry>
    </collision>
    <xacro:inertial_box mass="0.050" x="${palm_x}" y="${palm_y}" z="${palm_z}"/>
  </link>

  <!-- Left finger -->
  <joint name="joint_finger_left" type="prismatic">
    <parent link="gripper_base"/>
    <child  link="finger_left"/>
    <origin xyz="0 ${finger_spread} ${palm_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${gripper_lower}" upper="${gripper_upper}"
           effort="5.0" velocity="0.5"/>
    <dynamics damping="0.2" friction="0.05"/>
  </joint>

  <link name="finger_left">
    <visual>
      <origin xyz="0 0 ${finger_z/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${finger_x} ${finger_y} ${finger_z}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${finger_z/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${finger_x} ${finger_y} ${finger_z}"/>
      </geometry>
    </collision>
    <xacro:inertial_box mass="0.015" x="${finger_x}" y="${finger_y}" z="${finger_z}"/>
  </link>

  <!-- Right finger (mirrors left) -->
  <joint name="joint_finger_right" type="prismatic">
    <parent link="gripper_base"/>
    <child  link="finger_right"/>
    <origin xyz="0 ${-finger_spread} ${palm_z}" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="${gripper_lower}" upper="${gripper_upper}"
           effort="5.0" velocity="0.5"/>
    <dynamics damping="0.2" friction="0.05"/>
  </joint>

  <link name="finger_right">
    <visual>
      <origin xyz="0 0 ${finger_z/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${finger_x} ${finger_y} ${finger_z}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${finger_z/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${finger_x} ${finger_y} ${finger_z}"/>
      </geometry>
    </collision>
    <xacro:inertial_box mass="0.015" x="${finger_x}" y="${finger_y}" z="${finger_z}"/>
  </link>

  <!-- ============================================================
       CAMERA MODULE
       Mounted on gripper_base, pointing downward (-Z)
       Publishes via Gazebo camera sensor plugin
  ============================================================ -->

  <joint name="joint_camera" type="fixed">
    <parent link="gripper_base"/>
    <child  link="camera_link"/>
    <origin xyz="0 0 ${-camera_z}" rpy="${pi} 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${camera_x} ${camera_y} ${camera_z}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${camera_x} ${camera_y} ${camera_z}"/>
      </geometry>
    </collision>
    <xacro:inertial_box mass="0.010" x="${camera_x}" y="${camera_y}" z="${camera_z}"/>
  </link>

  <!-- Optical frame — Z forward, X right, Y down (ROS convention) -->
  <joint name="joint_camera_optical" type="fixed">
    <parent link="camera_link"/>
    <child  link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <link name="camera_optical_frame"/>

  <!-- ============================================================
       GAZEBO PLUGINS
  ============================================================ -->

  <!-- ros2_control plugin for Gazebo Harmonic -->
  <gazebo>
    <plugin filename="gz_ros2_control-system"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find the_hand_description)/config/ros2_controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <!-- Camera sensor -->
  <gazebo reference="camera_link">
    <sensor name="the_hand_camera" type="camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <topic>/camera/image_raw</topic>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>  <!-- 60 degrees -->
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.01</near>
          <far>5.0</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>

  <!-- Per-link Gazebo material overrides -->
  <gazebo reference="base_link">  <material>Gazebo/DarkGrey</material> </gazebo>
  <gazebo reference="link_1">     <material>Gazebo/Grey</material>     </gazebo>
  <gazebo reference="link_2">     <material>Gazebo/Grey</material>     </gazebo>
  <gazebo reference="link_3">     <material>Gazebo/Grey</material>     </gazebo>
  <gazebo reference="link_4">     <material>Gazebo/Turquoise</material></gazebo>
  <gazebo reference="link_5">     <material>Gazebo/Turquoise</material></gazebo>
  <gazebo reference="link_6">     <material>Gazebo/DarkGrey</material> </gazebo>
  <gazebo reference="gripper_base"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="finger_left"> <material>Gazebo/Black</material>   </gazebo>
  <gazebo reference="finger_right"><material>Gazebo/Black</material>   </gazebo>
  <gazebo reference="camera_link"> <material>Gazebo/Black</material>   </gazebo>

  <!-- ============================================================
       ros2_control HARDWARE INTERFACE
       Tells MoveIt/ros2_control about each joint.
       Uses sim hardware interface for Gazebo.
  ============================================================ -->

  <ros2_control name="the_hand_system" type="system">
    <hardware>
      <plugin>mock_components/GenericSystem</plugin>
    </hardware>

    <joint name="joint_1">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_2">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_3">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_4">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_5">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_6">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_finger_left">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_finger_right">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

</robot>
